# vim: set ft=zsh:

#===========#
# VARIABLES #
#===========#
export PATH=$HOME/gems/bin:$HOME/bin:/usr/local/bin:$HOME/.gem/ruby/2.7.0/bin:$PATH
export ZSH=$HOME/.oh-my-zsh
export GEM_HOME=$HOME/gems
export LANG=en_US.UTF-8
export EDITOR='nvim'
export SSH_KEY_PATH=$HOME/.ssh/id_rsa

#========#
# PROMPT #
#========#
{{- if eq .chezmoi.hostname "feoh" }}
ZSH_THEME="feoh"
DEFAULT_USER="abi"
{{- end }}
{{- if eq .chezmoi.hostname "prometheus" }}
ZSH_THEME="gay"
DEFAULT_USER="abby"
{{- end }}

#=========#
# OHMYZSH #
#=========#
CASE_SENSITIVE="false"
HYPHEN_INSENSITIVE="true"
DISABLE_AUTO_UPDATE="false"
COMPLETION_WAITING_DOTS="true"
DISABLE_UNTRACKED_FILES_DIRTY="true"

plugins=(git colored-man-pages virtualenv)
if which docker > /dev/null; then
    plugins+=docker
fi

source $ZSH/oh-my-zsh.sh

#=========#
# ALIASES #
#=========#
alias arch="neofetch"
alias ping="ping -c 3"
alias pingg="ping www.google.com"
alias ping8="ping 8.8.8.8"
alias c="clear"
alias ssh="TERM=xterm ssh"
alias vim="nvim"
alias vi="nvim"
alias v="nvim"
alias vimdiff="nvim -d"
alias oldvim="/usr/bin/vim"
alias :q="exit"
alias py="python"
alias woman="man"

if which thefuck > /dev/null; then
    eval $(thefuck --alias)
fi

#===========#
# FUNCTIONS #
#===========#
if which gs > /dev/null; then
    pdfmerge() {
        gs -dBATCH -dNOPAUSE -q -sDEVICE=pdfwrite -dPDFSETTINGS=/prepress -sOutputFile=$@ ;
    }
fi

venv() {
    if [[ ! -v VIRTUAL_ENV ]] ; then
        if [[ ! -z "$1" ]] ; then
            echo "Activating $1..."
            source ./$1/bin/activate
        else
            echo "No venv specified"
            return 1
        fi
    elif [[ -v VIRTUAL_ENV ]] ; then
        echo "Deactivating..."
        deactivate
    fi
}
